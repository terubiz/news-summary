# Database
POSTGRES_PASSWORD=apppassword

# JWT
JWT_SECRET=changeme-this-is-a-very-long-secret-key-for-jwt-signing-at-least-256-bits

# Encryption (AES-256-GCM key, must be 32 bytes)
ENCRYPTION_KEY=changeme-this-is-a-32-byte-key!

# Anthropic Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# News API (https://newsapi.org)
NEWS_API_KEY=your-news-api-key

# Stock API (https://www.alphavantage.co)
STOCK_API_KEY=your-alpha-vantage-api-key

# SMTP (for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Frontend
VITE_API_BASE_URL=http://localhost:8080
